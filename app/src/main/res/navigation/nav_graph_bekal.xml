<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph_bekal"
    app:startDestination="@id/fragmentDashboard">

    <fragment
        android:id="@+id/fragmentDashboard"
        android:name="com.example.bekalmu.FragmentDashboard"
        tools:layout="@layout/fragment_dashboard">
        <action
            android:id="@+id/action_dashboard_to_tambah"
            app:destination="@id/fragmentTambahStok" />
        <action
            android:id="@+id/action_dashboard_to_daftar"
            app:destination="@id/fragmentDaftarStok" />
        <action
            android:id="@+id/action_dashboard_to_detail"
            app:destination="@id/fragmentDetailStok" />
    </fragment>

    <fragment
        android:id="@+id/fragmentTambahStok"
        android:name="com.example.bekalmu.FragmentTambahStok"
        tools:layout="@layout/fragment_tambah_stok" />

    <fragment
        android:id="@+id/fragmentDaftarStok"
        android:name="com.example.bekalmu.FragmentDaftarStok"
        tools:layout="@layout/fragment_daftar_stok">
        <action
            android:id="@+id/action_daftar_to_detail"
            app:destination="@id/fragmentDetailStok" />
    </fragment>

    <fragment
        android:id="@+id/fragmentDetailStok"
        android:name="com.example.bekalmu.FragmentDetailStok"
        tools:layout="@layout/fragment_detail_stok" />

</navigation>