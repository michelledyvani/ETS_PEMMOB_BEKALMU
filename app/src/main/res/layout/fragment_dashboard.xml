<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_coklat"
    android:padding="24dp">

    <ImageView
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:src="@drawable/logo_bekalmu"
        android:alpha="0.3"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BekalMu POS"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="@color/Cokelat_Moka"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="32dp" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sistem Manajemen Stok UMKM"
        android:textSize="16sp"
        android:textColor="@color/text_gray"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cvRingkasan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Menu Terdaftar"
                android:textColor="@color/Cokelat_Moka"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvTotalMenu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="48sp"
                android:textStyle="bold"
                android:textColor="@color/Kuning_Bekal" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tvLabelHistori"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/Cokelat_Moka"
        app:layout_constraintTop_toBottomOf="@id/btnLihatDaftar"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cvHistori1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:visibility="gone"
        app:cardCornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvLabelHistori">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:orientation="horizontal">
            <TextView android:id="@+id/tvHistoriNama1" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Menu 1" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lihat Detail ❯" android:textColor="@color/blue_bekal" android:textSize="12sp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/cvHistori2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        app:cardCornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/cvHistori1">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:orientation="horizontal">
            <TextView android:id="@+id/tvHistoriNama2" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Menu 2" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lihat Detail ❯" android:textColor="@color/blue_bekal" android:textSize="12sp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/btnTambahStok"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="48dp"
        android:text="+ Tambah Stok Baru"
        android:textSize="16sp"
        android:backgroundTint="@color/Cokelat_Moka"
        app:layout_constraintTop_toBottomOf="@id/cvRingkasan" />

    <Button
        android:id="@+id/btnLihatDaftar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="16dp"
        android:text="Lihat Daftar Stok"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:backgroundTint="@color/Kuning_Bekal"
        app:layout_constraintTop_toBottomOf="@id/btnTambahStok" />

</androidx.constraintlayout.widget.ConstraintLayout>